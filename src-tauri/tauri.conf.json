{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BigEcho",
  "version": "2.1.0",
  "identifier": "com.bigecho.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "BigEcho",
        "width": 980,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$TEMP/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$APPCACHE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
